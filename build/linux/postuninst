#!/bin/bash

case "$1" in
  remove|purge|0)
    APP_BIN='/opt/clash-lite/clash-lite'

    if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
        systemctl stop clash-lite-core-helper.service >/dev/null 2>&1 || true
        systemctl disable clash-lite-core-helper.service >/dev/null 2>&1 || true
        rm -f /etc/systemd/system/clash-lite-core-helper.service 2>/dev/null || true
        systemctl daemon-reload >/dev/null 2>&1 || true
        systemctl reset-failed clash-lite-core-helper.service >/dev/null 2>&1 || true
    else
        rm -f /etc/systemd/system/clash-lite-core-helper.service 2>/dev/null || true
    fi

    rm -rf /run/clash-lite-core 2>/dev/null || true

    if type update-alternatives >/dev/null 2>&1; then
        update-alternatives --remove 'clash-lite' "$APP_BIN" 2>/dev/null || true
    fi
    
    [ -L '/usr/bin/clash-lite' ] && rm -f '/usr/bin/clash-lite'
    rm -f /etc/xdg/autostart/clash-lite.desktop 2>/dev/null || true

    if [ "$1" = "purge" ]; then
        rm -rf /root/.config/clash-lite /root/.cache/clash-lite 2>/dev/null || true

        if [ -d /home ]; then
            for home_dir in /home/*; do
                [ -d "$home_dir" ] || continue
                rm -rf "$home_dir/.config/clash-lite" "$home_dir/.cache/clash-lite" 2>/dev/null || true
                rm -f "$home_dir/.config/autostart/clash-lite.desktop" 2>/dev/null || true
            done
        fi
    fi

    if hash update-mime-database 2>/dev/null; then
      update-mime-database /usr/share/mime || true
    fi

    if hash update-desktop-database 2>/dev/null; then
        update-desktop-database /usr/share/applications || true
    fi

    # Update icon cache
    if hash gtk-update-icon-cache 2>/dev/null; then
        for dir in /usr/share/icons/hicolor /usr/share/icons/gnome; do
            [ -d "$dir" ] && gtk-update-icon-cache -f -t "$dir" 2>/dev/null || true
        done
    fi
    ;;
  *)
    # others
    ;;
esac
