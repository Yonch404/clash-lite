#!/bin/bash

set -e

if type update-alternatives >/dev/null 2>&1; then
    # Remove previous link if it doesn't use update-alternatives
    if [ -L '/usr/bin/clash-lite' ] && [ -e '/usr/bin/clash-lite' ] && [ "$(readlink '/usr/bin/clash-lite')" != '/etc/alternatives/clash-lite' ]; then
        rm -f '/usr/bin/clash-lite'
    fi
    update-alternatives --install '/usr/bin/clash-lite' 'clash-lite' '/opt/Clash Lite/clash-lite' 100 || ln -sf '/opt/Clash Lite/clash-lite' '/usr/bin/clash-lite'
else
    ln -sf '/opt/Clash Lite/clash-lite' '/usr/bin/clash-lite'
fi

chmod 4755 '/opt/Clash Lite/chrome-sandbox' 2>/dev/null || true

if [ -f '/opt/Clash Lite/resources/sidecar/mihomo' ]; then
    chmod 0755 '/opt/Clash Lite/resources/sidecar/mihomo' 2>/dev/null || true
    if command -v setcap >/dev/null 2>&1; then
        setcap 'cap_net_admin,cap_net_bind_service+ep' '/opt/Clash Lite/resources/sidecar/mihomo' 2>/dev/null || true
    fi
fi

if hash update-mime-database 2>/dev/null; then
    update-mime-database /usr/share/mime || true
fi

if hash update-desktop-database 2>/dev/null; then
    update-desktop-database /usr/share/applications || true
fi

# Update icon cache for GNOME/GTK environments
if hash gtk-update-icon-cache 2>/dev/null; then
    for dir in /usr/share/icons/hicolor /usr/share/icons/gnome; do
        [ -d "$dir" ] && gtk-update-icon-cache -f -t "$dir" 2>/dev/null || true
    done
fi

# Refresh GNOME Shell icon cache
if hash update-icon-caches 2>/dev/null; then
    update-icon-caches /usr/share/icons/* 2>/dev/null || true
fi
