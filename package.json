{
  "name": "clash-lite",
  "version": "1.2.1",
  "description": "Clash Lite",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "clash-lite",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --list-different .",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "review": "pnpm run format:check && pnpm run lint:check && pnpm run typecheck",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "prepare": "pnpm run hooks:install && node scripts/prepare.mjs",
    "prepare:dev": "pnpm run hooks:install && node scripts/update-version.mjs && node scripts/prepare.mjs",
    "updater": "node scripts/updater.mjs",
    "checksum": "node scripts/checksum.mjs",
    "dev": "electron-vite dev",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "electron-vite build && electron-builder --publish never --win",
    "build:win:dev": "pnpm run prepare:dev && electron-vite build && electron-builder --publish never --win",
    "build:linux": "electron-vite build && electron-builder --publish never --linux",
    "build:linux:dev": "pnpm run prepare:dev && electron-vite build && electron-builder --publish never --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2",
    "chokidar": "^5.0.0",
    "croner": "^10.0.1",
    "crypto-js": "^4.2.0",
    "express": "^5.2.1",
    "flag-icons": "^7.5.0",
    "i18next": "^26.0.7",
    "iconv-lite": "^0.7.2",
    "js-yaml": "^4.1.1",
    "plist": "^5.0.0",
    "qrcode.react": "^4.2.0",
    "sysproxy-rs": "file:src\\native\\sysproxy",
    "validator": "^13.15.35",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@heroui/react": "2.8.10",
    "@heroui/theme": "2.4.26",
    "@react-types/shared": "3.34.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pubsub-js": "^1.8.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitejs/plugin-react": "^5.2.0",
    "cron-validator": "^1.4.0",
    "dayjs": "^1.11.20",
    "driver.js": "^1.4.0",
    "electron": "^42.0.1",
    "electron-builder": "26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "electron-vite": "5.0.0",
    "electron-window-state": "^5.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "framer-motion": "12.38.0",
    "meta-json-schema": "^1.19.24",
    "monaco-editor": "0.52.2",
    "monaco-yaml": "^5.5.0",
    "nanoid": "^5.1.9",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "pubsub-js": "^1.9.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-monaco-editor": "^0.59.0",
    "react-router-dom": "^7.14.2",
    "react-virtuoso": "^4.18.7",
    "swr": "^2.4.1",
    "tailwindcss": "4.3.0",
    "terser": "^5.47.1",
    "tsx": "^4.21.0",
    "types-pac": "^1.0.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "electron",
      "electron-winstaller",
      "esbuild",
      "meta-json-schema"
    ]
  }
}
